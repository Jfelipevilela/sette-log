{
  "name": "sette-log",
  "private": true,
  "version": "0.1.0",
  "description": "Plataforma corporativa de gestao de frotas, telemetria, rastreamento e operacao.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace @sette-log/backend run dev",
    "dev:frontend": "npm --workspace @sette-log/frontend run dev",
    "dev:api": "npm --workspace @sette-log/backend run dev",
    "dev:web": "npm --workspace @sette-log/frontend run dev",
    "build": "npm --workspaces run build",
    "typecheck": "npm --workspaces run typecheck",
    "seed": "npm --workspace @sette-log/backend run seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.2.7"
  }
}
