NODE_ENV=production

# Mongo local via docker-compose.prod.yml
MONGO_INITDB_ROOT_USERNAME=sette_log
MONGO_INITDB_ROOT_PASSWORD=troque-esta-senha-forte
MONGO_INITDB_DATABASE=sette_log
MONGODB_URI=mongodb://sette_log:troque-esta-senha-forte@mongo:27017/sette_log?authSource=admin

# API
API_PORT=3333
API_PREFIX=api/v1
API_HOST=0.0.0.0
FRONTEND_URL=https://app.seu-dominio.com
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-access
JWT_REFRESH_SECRET=troque-por-um-segredo-forte-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
DEFAULT_TENANT_ID=sette-demo
REDIS_URL=redis://redis:6379

# Backup
BACKUP_ENABLED=true
BACKUP_HOUR=2
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=../backups/mongodb
MONGODUMP_PATH=mongodump
MONGODUMP_READ_PREFERENCE=secondaryPreferred

# Frontend
VITE_API_URL=/api/v1
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
